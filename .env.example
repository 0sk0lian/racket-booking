# ─── Database (Supabase Postgres in prod, local pg in dev if you prefer) ─
# Use the Supabase "Connection string" (Session pooler at port 6543 for app
# code on Vercel; Direct connection at port 5432 only for migrations).
DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:6543/postgres
# Direct (5432) connection used by packages/db/migrate.js — required because
# migrations need session-level commands that the transaction pooler rejects.
DATABASE_URL_DIRECT=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Personal access token for the Supabase CLI (Account → Tokens). Goes in .env, NOT .env.example.
SUPABASE_ACCESS_TOKEN=sbp_...
# Service role bypasses RLS. NEVER expose to the browser. Only used in
# server-side API routes (Next.js Route Handlers) for admin operations.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Public-safe variants exposed to the consumer Next.js + mobile app.
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Connect — set after the platform is approved for Connect by Stripe
STRIPE_CONNECT_CLIENT_ID=ca_...

# ─── Swish (Sweden-only, optional at first) ───────────────────────────────
SWISH_API_URL=https://mss.cpc.getswish.net/swish-cpcapi/api/v2
SWISH_CERT_PATH=./certs/swish.pem
SWISH_CERT_KEY_PATH=./certs/swish.key

# ─── IoT Hardware ─────────────────────────────────────────────────────────
NOX_API_KEY=...
NOX_API_URL=https://api.nox-controllers.com/v1

# ─── Email (transactional) ────────────────────────────────────────────────
# Resend or Postmark — pick one in Phase H
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@<your-domain>

# ─── Rate limiting (Phase D) ──────────────────────────────────────────────
# Vercel KV or Upstash Redis. Get from Vercel Storage / Upstash console.
KV_REST_API_URL=https://<region>.upstash.io
KV_REST_API_TOKEN=...

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}

# ─── App config ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated allowed origins for CORS (Phase D). Empty/unset = dev mode.
CORS_ORIGINS=https://<your-domain>,https://app.<your-domain>

# ─── Mobile (Expo) ────────────────────────────────────────────────────────
# Read from app.json env block at build time; mobile uses the public Supabase
# vars above plus this base API URL.
EXPO_PUBLIC_API_URL=https://<your-domain>/api

# ─── Deprecated after Phase B (Supabase Auth migration) ───────────────────
# Kept for the dev period while the in-memory store still serves requests.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── Redis (BullMQ job queue, Phase J) ────────────────────────────────────
# Will move to Inngest or Supabase Edge Functions when we revisit background
# jobs. Keep here for backward compat until then.
REDIS_URL=redis://localhost:6379
