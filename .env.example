# Database
DATABASE_URL=postgresql://user:password@localhost:5432/racket_booking

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Swish / Trustly
SWISH_API_URL=https://mss.cpc.getswish.net/swish-cpcapi/api/v2
SWISH_CERT_PATH=./certs/swish.pem
SWISH_CERT_KEY_PATH=./certs/swish.key

# IoT Hardware
NOX_API_KEY=...
NOX_API_URL=https://api.nox-controllers.com/v1

# Redis (for BullMQ job scheduling)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
